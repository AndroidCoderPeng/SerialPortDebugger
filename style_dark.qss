/* ============================================
   SerialPortDebugger — 暗色主题
   主色调: #007AFF (blue accent)
   ============================================ */

/* ====== 全局背景 ====== */
QMainWindow {
    background-color: #1E1E2E;
}

QDialog {
    background-color: #242436;
}

QLabel {
    color: #D4D4D4;
}

/* ====== QComboBox ====== */
QComboBox {
    background-color: #28283C;
    color: #D4D4D4;
    border: 1px solid #404058;
    padding: 3px 7px;
    border-radius: 3px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: 1px solid #404058;
}

QComboBox::down-arrow {
    image: url(:/combox_arrow.png);
    width: 16px;
    height: 16px;
}

QComboBox:hover {
    border-color: #007AFF;
}

QComboBox::drop-down:hover {
    border-color: #007AFF;
}

QComboBox::down-arrow:hover {
    image: url(:/combox_arrow_007aff.png);
}

QComboBox QAbstractItemView {
    border: 1px solid #007AFF;
    background: #28283C;
    color: #D4D4D4;
    selection-color: #FFFFFF;
    outline: 0;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #007AFF;
    color: #FFFFFF;
}

QComboBox QAbstractItemView::item:hover {
    background-color: rgba(0, 122, 255, 0.22);
    color: #D4D4D4;
}

QComboBox:disabled {
    background-color: #333348;
    color: #707080;
    border-color: #505060;
}

/* ====== QPushButton ====== */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #007AFF, stop:1 #0060DB);
    color: #FFFFFF;
    border: none;
    padding: 5px 10px;
    border-radius: 4px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #0070EA, stop:1 #0056CC);
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #0060DB, stop:1 #004AAD);
}

QPushButton:disabled {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #505068, stop:1 #44445A);
    color: #909090;
}

/* 取消按钮 */
QPushButton#cancelButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #3A3A50, stop:1 #2E2E42);
    color: #D4D4D4;
    border: 1px solid #505068;
}

QPushButton#cancelButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                 stop:0 #454560, stop:1 #38384E);
    border-color: #007AFF;
}

/* ====== QTabWidget ====== */
QTabWidget::pane {
    border: 1px solid #404058;
}

QTabBar::tab {
    background-color: #28283C;
    color: #909090;
    padding: 4px 12px;
}

QTabBar::tab:selected {
    color: #D4D4D4;
    background-color: #242436;
}

QTabBar::tab:hover:!selected {
    color: #B0B0B0;
}

/* ====== QListWidget ====== */
QListWidget {
    background-color: #28283C;
    color: #D4D4D4;
    border: none;
}

QListWidget::item:hover {
    background-color: rgba(0, 122, 255, 0.08);
}

QListWidget::item:selected {
    background-color: rgba(0, 122, 255, 0.18);
    color: #FFFFFF;
}

/* 横向可拖动 item 的 QListWidget */
QListWidget#horizontalListWidget {
    padding: 5px 4px;
    font-size: 10pt;
    outline: none;
    background-color: #28283C;
    color: #D4D4D4;
}

QListWidget#horizontalListWidget::item {
    margin-right: 8px;
    padding: 0px 8px;
    border: 1px solid #404058;
    border-radius: 4px;
    background-color: #333350;
}

QListWidget#horizontalListWidget::item:selected {
    background-color: #007AFF;
    color: #FFFFFF;
}

/* ====== QPlainTextEdit ====== */
QPlainTextEdit {
    border: 1px solid #404058;
    background-color: #28283C;
    color: #D4D4D4;
}

QPlainTextEdit:hover {
    border: 1px solid #007AFF;
}

/* ====== QTextEdit ====== */
QTextEdit {
    background-color: #28283C;
    color: #D4D4D4;
    border: 1px solid #404058;
    border-radius: 3px;
}

QTextEdit:hover {
    border: 1px solid #007AFF;
}

/* ====== QLineEdit ====== */
QLineEdit {
    background-color: #28283C;
    color: #D4D4D4;
    border: 1px solid #404058;
    border-radius: 3px;
    padding: 3px;
}

QLineEdit:hover {
    border: 1px solid #007AFF;
}

/* ====== QCheckBox ====== */
QCheckBox {
    color: #D4D4D4;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked {
    image: url(:/checkbox_unchecked.png);
}

QCheckBox::indicator:checked {
    image: url(:/checkbox_checked.png);
}

QCheckBox::indicator:hover {
    /* 图片自带 hover 效果则留空 */
}

/* ====== QListView ====== */
QListView {
    background-color: #28283C;
    color: #D4D4D4;
    border: none;
    font-size: 10pt;
    outline: none;
}

QListView::item {
    padding: 6px 0px;
}

QListView::item:hover {
    background-color: rgba(0, 122, 255, 0.08);
}

QListView::item:selected {
    background-color: rgba(0, 122, 255, 0.18);
    color: #FFFFFF;
}

/* ====== QMenu ====== */
QMenu {
    background-color: #28283C;
    color: #D4D4D4;
    border: 1px solid #404058;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px;
    border-radius: 3px;
}

QMenu::item:selected {
    background-color: rgba(0, 122, 255, 0.18);
    color: #FFFFFF;
}

QMenu::separator {
    height: 1px;
    background: #404058;
    margin: 4px 8px;
}

/* ====== QMessageBox / QDialog ====== */
QMessageBox {
    background-color: #28283C;
}

QMessageBox QLabel {
    color: #D4D4D4;
}

/* ====== QScrollBar (vertical) ====== */
QScrollBar:vertical {
    background: #1E1E2E;
    width: 8px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #505068;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #007AFF;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

/* ====== QScrollBar (horizontal) ====== */
QScrollBar:horizontal {
    background: #1E1E2E;
    height: 8px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #505068;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: #007AFF;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}
